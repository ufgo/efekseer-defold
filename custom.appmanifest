platforms:
  arm64-osx:
    context:
      excludeLibs: [graphics_vulkan, platform_vulkan, MoltenVK]
      excludeSymbols: [GraphicsAdapterVulkan]
      symbols: [GraphicsAdapterOpenGL]
      libs: [graphics, platform]
      frameworks: [OpenGL]
  x86_64-osx:
    context:
      excludeLibs: [graphics_vulkan, platform_vulkan, MoltenVK]
      excludeSymbols: [GraphicsAdapterVulkan]
      symbols: [GraphicsAdapterOpenGL]
      libs: [graphics, platform]
      frameworks: [OpenGL]
